# =============================================================================
# TESTSERIES BACKEND - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# REQUIRED: MongoDB connection string
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/

# REQUIRED: MongoDB database name
DB_NAME=testseries

# REQUIRED: JWT secret for token generation (use a strong random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-here

# REQUIRED: Admin user credentials (used during seeding)
ADMIN_EMAIL=admin@testseries.local
ADMIN_PASSWORD=change-this-strong-password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS: Frontend origin (change to your deployed domain)
# Examples:
#   Development: http://localhost:3000
#   Production: https://yourdomain.com
# DEFAULT: http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# OTP Exposure: Set to 'true' ONLY in development for debugging
# In production, keep this 'false' so OTPs are not exposed through API
# DEFAULT: false
EXPOSE_OTP=false

# =============================================================================
# RAZORPAY PAYMENT INTEGRATION (Optional - Production Only)
# =============================================================================
# Leave these empty for development. The system will work without them.
# Add these values in Vercel environment after setting up Razorpay account.

# Razorpay Key ID (get from Razorpay dashboard)
RAZORPAY_KEY_ID=

# Razorpay Key Secret (get from Razorpay dashboard)
RAZORPAY_KEY_SECRET=